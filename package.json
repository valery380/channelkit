{
  "name": "channelkit",
  "version": "0.1.0",
  "description": "A self-hosted messaging gateway that connects chat channels to any application via webhooks",
  "main": "dist/index.js",
  "bin": {
    "channelkit": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/dashboard dist/",
    "start": "tsx src/cli.ts start",
    "dev": "tsx watch src/cli.ts start",
    "init": "tsx src/cli.ts init",
    "service": "tsx src/cli.ts service"
  },
  "keywords": [
    "whatsapp",
    "telegram",
    "messaging",
    "gateway",
    "webhook",
    "chatbot"
  ],
  "author": "dirbalak",
  "license": "MIT",
  "private": true,
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/hapi__boom": "^7.4.1",
    "@types/node": "^25.3.0",
    "@types/ws": "^8.18.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.6.2",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "grammy": "^1.40.0",
    "qrcode-terminal": "^0.12.0",
    "tsx": "^4.21.0",
    "twilio": "^5.12.2",
    "typescript": "^5.9.3",
    "ws": "^8.19.0",
    "yaml": "^2.8.2"
  }
}

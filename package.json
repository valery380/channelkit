{
  "name": "@dirbalak/channelkit",
  "version": "0.1.28",
  "description": "A self-hosted messaging gateway that connects chat channels to any application via webhooks",
  "main": "dist/index.js",
  "bin": {
    "channelkit": "dist/cli.js"
  },
  "files": [
    "dist/",
    "config.example.yaml",
    "echo-server.js",
    "SKILL.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "build": "tsc && cd src/dashboard && npx vite build",
    "build:dashboard": "cd src/dashboard && npx vite build",
    "start": "NODE_NO_WARNINGS=1 tsx src/cli.ts start",
    "dev": "npm run build:dashboard && NODE_NO_WARNINGS=1 tsx watch src/cli.ts start",
    "init": "NODE_NO_WARNINGS=1 tsx src/cli.ts init",
    "service": "NODE_NO_WARNINGS=1 tsx src/cli.ts service",
    "channel": "NODE_NO_WARNINGS=1 tsx src/cli.ts channel",
    "demo": "NODE_NO_WARNINGS=1 tsx src/cli.ts demo",
    "postinstall": "echo \"\n  ✅ ChannelKit installed!\n\n  Run 'channelkit' to get started.\n\""
  },
  "keywords": [
    "whatsapp",
    "telegram",
    "messaging",
    "gateway",
    "webhook",
    "chatbot"
  ],
  "author": "dirbalak",
  "license": "MIT",
  "preferGlobal": true,
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/hapi__boom": "^7.4.1",
    "@types/node": "^25.3.0",
    "@types/ws": "^8.18.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.6.2",
    "cloudflared": "^0.7.1",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "grammy": "^1.40.0",
    "helmet": "^8.1.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.21.0",
    "twilio": "^5.12.2",
    "typescript": "^5.9.3",
    "ws": "^8.19.0",
    "yaml": "^2.8.2"
  },
  "peerDependenciesMeta": {
    "@whiskeysockets/baileys": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-react": "^4.7.0",
    "tailwindcss": "^4.2.1",
    "vite": "^6.4.1"
  }
}
